<% layout("/layouts/boilerplate") %>

<!-- HERO SECTION -->

<div class="hero">

  <div class="hero-content">

    <h1 class="hero-title">Find Your Perfect Stay</h1>

    <form class="hero-search" action="/listings/search" method="GET">

      <input 
      type="search"
      name="q"
      placeholder="Search destinations..."
      class="hero-input">

      <button type="submit" class="hero-btn">
        Search
      </button>

    </form>

  </div>

</div>



<!-- LISTINGS -->

<div class="container mt-5">

  <h2 class="text-center mb-5 fw-bold main-title">Explore Amazing Places</h2>

  <div class="row g-4 row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

    <% for(let listing of allListings) { %>

      <div class="col">

        <a href="/listings/<%= listing._id %>" class="listing-link">

          <div class="card listing-card">

            <img 
            src="<%= listing.image.url %>"
            class="card-img-top"
            alt="listing_image">

            <div class="card-body">

              <h5 class="card-title fw-semibold">
                <%= listing.title %>
              </h5>

              <p class="price">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
                <span class="night-text"> / night</span>
              </p>

            </div>

          </div>

        </a>

      </div>

    <% } %>

  </div>

</div>